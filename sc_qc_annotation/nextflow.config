/*
 * Nextflow config for H5AD single-cell QC preprocessing pipeline
 */

nextflow.enable.dsl = 2

params {
    input_dir = null
    outdir = "results"
    threads = 4
    min_genes = 200
    min_counts = 500
    n_mads = 3.0
    mt_cutoff = null
    expected_doublet_rate = 0.06
    skip_doublets = false
}

process {
    container = "getwilds/scanpy:1.10.2"
    cpus = 4
    memory = "16 GB"
}

docker {
    enabled = true
}

singularity {
    enabled = false
}

manifest {
    name = "h5ad-single-cell-qc"
    author = "Cirro custom pipelines"
    description = "Scan dataset for h5ad files and run single-cell QC preprocessing"
    version = "1.0.0"
    nextflowVersion = ">=22.10.0"
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_info/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/trace.txt"
}
